# Copy this file to .env for local OpenAI experimentation. .env is gitignored.
RETAILHERO_DATA_DIR=retailhero-uplift/data

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_PLANNING_MODEL=o3
LLM_EVALUATION_MODEL=o4-mini

OPENAI_API_KEY=PASTE_YOUR_OPENAI_API_KEY_HERE
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

BT5153_MAX_ITERATIONS=3
BT5153_RUN_BENCHMARK=true
